{
  "extends": "@vue/tsconfig/tsconfig.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "**/*.d.ts"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "lib": ["ES2022"],
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "Node",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["naive-ui/volar", "unplugin-icons/types/vue"],
    "esModuleInterop": true,
    "jsx": "preserve",
    "skipLibCheck": true
  }
}
